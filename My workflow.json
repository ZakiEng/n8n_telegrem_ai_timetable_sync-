    {
      "parameters": {
        "jsCode": "// التأكد من استلام النص من مخرج الـ AI Agent\nlet aiResponse = items[0].json.output; \n\n// تنظيف النص في حال وجود علامات ```json\naiResponse = aiResponse.replace(/```json/g, \"\").replace(/```/g, \"\").trim();\n\ntry {\n    const scheduleArray = JSON.parse(aiResponse);\n    \n    // تحويل المصفوفة إلى تنسيق متوافق مع نود Google Sheets\n    return scheduleArray.map(item => {\n        return {\n            json: {\n                \"اليوم\": item.day,\n                \"المادة\": item.subject,\n                \"وقت البدء\": item.start_time,\n                \"وقت الانتهاء\": item.end_time\n            }\n        };\n    });\n} catch (error) {\n    throw new Error(\"فشل في تحليل مخرجات الذكاء الاصطناعي، تأكد من أن البرومبت يعمل بشكل صحيح.\");\n}"
